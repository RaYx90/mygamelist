# Copy this file to .env and fill in the values
# Never commit .env to source control

# SQL Server SA password (min 8 chars, uppercase + lowercase + number + symbol)
DB_PASSWORD=GameList_Prod_2026!

# IGDB / Twitch credentials
# Register at: https://dev.twitch.tv/console
IGDB_CLIENT_ID=your_twitch_client_id_here
IGDB_CLIENT_SECRET=your_twitch_client_secret_here

# Código secreto de registro — sin este código no es posible crear cuenta
